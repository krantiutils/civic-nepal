<Window x:Class="NagarikPatro.Views.CalendarPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NagarikPatro.ViewModels"
        Title="Nagarik Patro"
        Width="340" Height="460"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="Transparent">

    <Window.DataContext>
        <vm:CalendarViewModel/>
    </Window.DataContext>

    <Border CornerRadius="8" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
            BorderThickness="1" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
        <DockPanel>
            <!-- Month Navigation Header -->
            <Border DockPanel.Dock="Top" Padding="8" Background="#0A3B82F6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="◀" Click="PreviousMonth_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding MonthHeaderNp}" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" FontFamily="Nirmala UI"/>
                        <TextBlock Text="{Binding MonthHeaderEn}" FontSize="11"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="▶" Click="NextMonth_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                </Grid>
            </Border>

            <Separator DockPanel.Dock="Top"/>

            <!-- Today Card -->
            <Border DockPanel.Dock="Top" Padding="12" Background="#08000000">
                <StackPanel Orientation="Horizontal">
                    <Border Width="48" Height="48" CornerRadius="8" Background="#3B82F6">
                        <TextBlock Text="{Binding TodayDayNp}" FontSize="20" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontFamily="Nirmala UI"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="13" FontWeight="SemiBold" FontFamily="Nirmala UI">
                            <Run Text="आज: "/><Run Text="{Binding TodayNpFormatted, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}">
                            <Run Text="{Binding TodayWeekdayNp, Mode=OneWay}"/>
                            <Run Text=" • "/>
                            <Run Text="{Binding TodayAdFormatted, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Separator DockPanel.Dock="Top"/>

            <!-- Upcoming Google Calendar Events -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,0">
                <TextBlock Text="Upcoming" FontSize="11" FontWeight="SemiBold" Margin="12,8,12,4"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>

                <!-- Sign in prompt (no cached data) -->
                <Button Content="Sign in via Nagarik Patro" Margin="12,0,12,8"
                        Click="OpenApp_Click" Style="{StaticResource OpenAppButtonStyle}" Height="28" FontSize="11"
                        Visibility="{Binding ShowGoogleSignInPrompt, Converter={StaticResource BoolToVisibility}}"/>

                <!-- No upcoming events -->
                <TextBlock Text="No upcoming events" FontSize="11" Margin="12,0,12,8"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Visibility="{Binding NoUpcomingGoogleEvents, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Event list -->
                <ItemsControl ItemsSource="{Binding UpcomingGoogleEvents}" Margin="8,0,8,8"
                              Visibility="{Binding HasUpcomingGoogleEvents, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,1" Padding="4,2" CornerRadius="4"
                                    Background="{Binding ColorBrushLight}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="3" CornerRadius="1.5" Margin="0,2,6,2"
                                            Background="{Binding ColorBrush}"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding TimeDisplay}" FontSize="9"
                                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Separator DockPanel.Dock="Top"/>

            <!-- Open App Button -->
            <Button DockPanel.Dock="Bottom" Content="Open Nagarik Patro" Margin="8"
                    Click="OpenApp_Click" Style="{StaticResource OpenAppButtonStyle}"/>

            <Separator DockPanel.Dock="Bottom"/>

            <!-- Calendar Grid -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Weekday Headers -->
                    <UniformGrid Rows="1" Columns="7" Margin="0,6,0,6">
                        <TextBlock Text="आ" Style="{StaticResource WeekdayHeaderStyle}" FontFamily="Nirmala UI"/>
                        <TextBlock Text="सो" Style="{StaticResource WeekdayHeaderStyle}" FontFamily="Nirmala UI"/>
                        <TextBlock Text="मं" Style="{StaticResource WeekdayHeaderStyle}" FontFamily="Nirmala UI"/>
                        <TextBlock Text="बु" Style="{StaticResource WeekdayHeaderStyle}" FontFamily="Nirmala UI"/>
                        <TextBlock Text="बि" Style="{StaticResource WeekdayHeaderStyle}" FontFamily="Nirmala UI"/>
                        <TextBlock Text="शु" Style="{StaticResource WeekdayHeaderStyle}" FontFamily="Nirmala UI"/>
                        <TextBlock Text="श" Style="{StaticResource WeekdayHeaderSatStyle}" FontFamily="Nirmala UI"/>
                    </UniformGrid>

                    <!-- Calendar days are rendered in code-behind using UniformGrid -->
                    <UniformGrid x:Name="CalendarGrid" Columns="7"/>

                    <!-- Selected Day Events -->
                    <ItemsControl x:Name="EventsList" Margin="12,8"
                                  ItemsSource="{Binding SelectedDayEvents}"
                                  Visibility="{Binding HasSelectedDayContent, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Ellipse Width="6" Height="6" Margin="0,4,6,0" VerticalAlignment="Top">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="Orange"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHoliday}" Value="True">
                                                        <Setter Property="Fill" Value="Red"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <StackPanel>
                                        <TextBlock Text="{Binding EventNp}" FontSize="12" FontFamily="Nirmala UI"/>
                                        <TextBlock Text="{Binding EventEn}" FontSize="10"
                                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
